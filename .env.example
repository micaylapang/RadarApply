# Supabase (Dashboard → Project Settings → API)
# Newer projects show "Publishable" + "Secret" instead of anon/service_role —
# those map 1:1 to the vars below.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...   # Publishable key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...            # Secret key

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TRIAL_MODE=false
TWILIO_TRIAL_TEMPLATE=sms_event_notifications

# Local in-process loop (skipped automatically on Vercel)
POLL_INTERVAL_MS=1000
MONITOR_ENABLED=true

# Vercel Cron — must match the CRON_SECRET env var in the Vercel project
CRON_SECRET=replace_with_a_long_random_string

# Optional: used to sign login session cookies (falls back to CRON_SECRET)
AUTH_SECRET=

# Admin signup report (/admin) — falls back to CRON_SECRET if unset
ADMIN_SECRET=

# Signup ops email (Resend — https://resend.com)
# Create a free API key, then add it here + on Vercel.
# Sign up at Resend with radarapply@gmail.com so onboarding@resend.dev can deliver to it.
RESEND_API_KEY=
SIGNUP_NOTIFY_EMAIL=radarapply@gmail.com
# Optional once you verify a domain: EMAIL_FROM="RadarApply <alerts@yourdomain.com>"
EMAIL_FROM=

# Google Sheets — live signup log (Apps Script web app)
# See scripts/google-sheets-signup-webhook.gs for the sheet-side script.
GOOGLE_SHEETS_WEBHOOK_URL=
# Optional shared secret (must match WEBHOOK_SECRET in the Apps Script)
GOOGLE_SHEETS_WEBHOOK_SECRET=

# Public site URL (Stripe checkout redirects). On Vercel, falls back to VERCEL_URL.
NEXT_PUBLIC_APP_URL=https://www.radarapply.com

# Stripe — $10 Summer 2027 season pass
# Dashboard → Developers → API keys + Webhooks
# Webhook endpoint: https://www.radarapply.com/api/billing/webhook
# Listen for: checkout.session.completed
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
