# Supabase (Dashboard → Project Settings → API)
# Newer projects show "Publishable" + "Secret" instead of anon/service_role —
# those map 1:1 to the vars below.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...   # Publishable key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...            # Secret key

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TRIAL_MODE=false
TWILIO_TRIAL_TEMPLATE=sms_event_notifications

# Local in-process loop (skipped automatically on Vercel)
POLL_INTERVAL_MS=1000
MONITOR_ENABLED=true

# Vercel Cron — must match the CRON_SECRET env var in the Vercel project
CRON_SECRET=replace_with_a_long_random_string

# Optional: protect POST /api/demo/open
DEMO_TRIGGER_SECRET=
